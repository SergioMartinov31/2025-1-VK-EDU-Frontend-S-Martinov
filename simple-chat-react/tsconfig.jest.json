{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": ".jest-build",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "inlineSources": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.test.ts"],
  "exclude": ["node_modules", "dist", ".jest-build"]
}
